@model LoginViewModel
@{ ViewData["Title"] = "Giriş"; }
<section class="login-card">
    <div class="login-brand">
        @if (!string.IsNullOrWhiteSpace(Model.Brand.LogoPath))
        {
            <img src="@Model.Brand.LogoPath" alt="@Model.Brand.Name logosu" />
        }
        else
        {
            <span class="brand-wordmark" aria-label="@Model.Brand.Name">@Model.Brand.Name</span>
        }
    </div>
    <div class="eyebrow">@Model.Brand.Eyebrow</div>
    <h1>@Model.Brand.LoginHeading</h1>
    <p>@Model.Brand.LoginDescription</p>
    <form method="post">
        <label asp-for="Email">E-posta</label>
        <input asp-for="Email" autocomplete="username" />
        <span asp-validation-for="Email"></span>
        <label asp-for="Password">Parola</label>
        <input asp-for="Password" autocomplete="current-password" />
        <span asp-validation-for="Password"></span>
        @if (Model.Error is not null) { <div class="error">@Model.Error</div> }
        <button type="submit">Giriş yap</button>
    </form>
</section>
