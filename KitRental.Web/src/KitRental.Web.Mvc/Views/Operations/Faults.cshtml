@model IReadOnlyCollection<FaultViewModel>
@{ ViewData["Title"] = "Arızalar"; }
<div class="page-heading"><div><span class="eyebrow">SERVİS &amp; DESTEK</span><h1>Arıza Kayıtları</h1></div></div>
@functions { string StatusName(int value) => value switch { 1 => "Açık", 2 => "İnceleniyor", 3 => "Müşteri bilgisi bekleniyor", 4 => "Kit bekleniyor", 5 => "Serviste", 6 => "Geri gönderiliyor", 7 => "Çözüldü", 8 => "Kapalı", _ => "İşlemde" }; }
@if (TempData["Success"] is string success) { <div class="success-banner">@success</div> }
@if (TempData["Error"] is string error) { <div class="error-banner">@error</div> }
<div class="table-scroll"><table><thead><tr><th>Numara</th><th>Kategori</th><th>Açıklama</th><th>Önem</th><th>Durum</th><th>Süreç güncelle</th></tr></thead>
<tbody>@foreach (var item in Model) { <tr><td><strong>@item.Number</strong></td><td>@item.Category</td><td>@item.Description</td><td>@item.Severity</td><td><span class="badge">@StatusName(item.Status)</span></td><td>@if (item.Status is not (7 or 8)) { <form class="fault-update-form" asp-action="UpdateFault" asp-route-id="@item.Id" method="post"><select name="status"><option value="2">İnceleniyor</option><option value="3">Müşteri bilgisi bekleniyor</option><option value="4">Kitin gönderilmesi bekleniyor</option><option value="5">Serviste</option><option value="6">Geri gönderiliyor</option><option value="7">Çözüldü</option><option value="8">Kapatıldı</option></select><input name="note" required placeholder="Müşterinin göreceği süreç notu" /><button class="table-action" type="submit">Güncelle</button></form> }</td></tr> }</tbody></table></div>
@if (Model.Count == 0) { <div class="empty">Açık arıza kaydı yok.</div> }
