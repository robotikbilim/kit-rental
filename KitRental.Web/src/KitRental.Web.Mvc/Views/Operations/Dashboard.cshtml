@model DashboardViewModel
@{ ViewData["Title"] = "Genel Bakış"; }
<div class="page-heading"><div><span class="eyebrow">CANLI OPERASYON</span><h1>Genel Bakış</h1></div><span class="status-dot">Sistem çalışıyor</span></div>
@if (Model is null) { <div class="empty">Core servisine ulaşılamadı.</div> }
else {
<div class="metrics">
    <a class="metric-card" asp-action="Orders" aria-label="Müşterileri siparişler sayfasında görüntüle"><span>Müşteriler</span><strong>@Model.Customers</strong><small>Siparişlere git →</small></a>
    <a class="metric-card" asp-action="Inventory" aria-label="Fiziksel birimleri envanter sayfasında görüntüle"><span>Fiziksel birimler</span><strong>@Model.ProductUnits</strong><small>Envantere git →</small></a>
    <a class="metric-card" asp-action="Orders" aria-label="Aktif siparişleri görüntüle"><span>Aktif siparişler</span><strong>@Model.ActiveOrders</strong><small>Siparişlere git →</small></a>
    <a class="metric-card" asp-action="Faults" aria-label="Açık arızaları görüntüle"><span>Açık arızalar</span><strong>@Model.OpenFaults</strong><small>Arızalara git →</small></a>
    <a class="metric-card" asp-action="Inventory" aria-label="Bakımdaki fiziksel birimleri görüntüle"><span>Bakımda</span><strong>@Model.UnitsInMaintenance</strong><small>Envantere git →</small></a>
</div>
}
