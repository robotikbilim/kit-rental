@model PrepareOrderKitsViewModel
@{ ViewData["Title"] = "Sipariş Kitlerini Oluştur"; }
<div class="form-shell form-shell-wide">
    <div class="form-heading"><a asp-action="OrderDetails" asp-route-id="@Model.OrderId">← Sipariş detayına dön</a><span class="eyebrow">@Model.OrderNumber</span><h1>Fiziksel kitleri yapılandır</h1><p>@Model.CustomerName için siparişte yer alacak ürünleri ve adetleri son kez düzenleyin.</p></div>
    <form class="catalog-form" asp-action="PrepareOrderKits" method="post">
        <input type="hidden" asp-for="OrderId" />
        <div asp-validation-summary="All" class="error"></div>
        <div class="form-section"><div class="section-heading"><div><h2>Sipariş kapsamındaki kitler</h2><p>Ürün ekleyebilir, satır çıkarabilir ve adetleri değiştirebilirsiniz.</p></div><button class="secondary-action" type="button" id="add-order-kit-line">+ Ürün ekle</button></div>
            <div class="recipe-lines" id="order-kit-lines">
            @for (var i = 0; i < Model.Lines.Count; i++)
            {
                <div class="recipe-line order-kit-line"><span class="line-number">@(i + 1)</span><div class="field"><label>Eğitim kiti</label><select name="Lines[@i].ProductModelId"><option value="">Kit seçin</option>@foreach (var kit in Model.ProductModels) { <option value="@kit.Id" selected="@(kit.Id == Model.Lines[i].ProductModelId)">@kit.Name (@kit.Sku)</option> }</select></div><div class="field quantity-field"><label>Adet</label><input type="number" min="1" max="200" name="Lines[@i].Quantity" value="@Model.Lines[i].Quantity" /></div><button class="remove-line" type="button" title="Satırı kaldır">×</button></div>
            }
            </div>
        </div>
        <div class="order-kit-confirm-note">
            <input asp-for="UseAvailableKits" type="checkbox" />
            <label asp-for="UseAvailableKits"><strong>Stoktaki hazır kitlerden kullan</strong><span class="block-muted">İşaretlendiğinde uygun fiziksel kitler önce rezerve edilir; yalnız eksik adetler için yeni fiziksel kit üretilir.</span></label>
        </div>
        <div class="form-actions"><a class="secondary-action" asp-action="OrderDetails" asp-route-id="@Model.OrderId">Vazgeç</a><button class="primary-action" type="submit">Onayla ve kitleri rezerve et</button></div>
    </form>
</div>
<template id="order-kit-line-template"><div class="recipe-line order-kit-line"><span class="line-number"></span><div class="field"><label>Eğitim kiti</label><select data-name="ProductModelId"><option value="">Kit seçin</option>@foreach (var kit in Model.ProductModels) { <option value="@kit.Id">@kit.Name (@kit.Sku)</option> }</select></div><div class="field quantity-field"><label>Adet</label><input data-name="Quantity" type="number" min="1" max="200" value="1" /></div><button class="remove-line" type="button" title="Satırı kaldır">×</button></div></template>
<script>
(() => { const box=document.querySelector('#order-kit-lines'),tpl=document.querySelector('#order-kit-line-template');
 const renumber=()=>[...box.querySelectorAll('.order-kit-line')].forEach((row,i)=>{row.querySelector('.line-number').textContent=i+1;row.querySelectorAll('[name],[data-name]').forEach(el=>{const field=el.dataset.name||el.name.split('.').pop();el.name=`Lines[${i}].${field}`;});});
 document.querySelector('#add-order-kit-line').addEventListener('click',()=>{box.append(tpl.content.cloneNode(true));renumber();});
 box.addEventListener('click',e=>{if(!e.target.classList.contains('remove-line'))return;if(box.children.length>1)e.target.closest('.order-kit-line').remove();else{box.querySelector('select').value='';box.querySelector('input').value=1;}renumber();});renumber(); })();
</script>
