@model AdminOrderPageViewModel
@{ ViewData["Title"] = "Sipariş Oluştur"; }
<div class="form-shell form-shell-wide">
    <div class="form-heading"><a asp-action="Orders">← Siparişlere dön</a><span class="eyebrow">YENİ SİPARİŞ</span><h1>Yönetici siparişi oluştur</h1><p>Müşteriyi, teslimat adresini, kitleri ve kiralama dönemini belirleyin. Sipariş önce onay bekleyenler listesine eklenir.</p></div>
    <form class="catalog-form" asp-action="CreateOrder" method="post">
        <div asp-validation-summary="All" class="error"></div>
        <div class="form-section"><h2>Müşteri ve teslimat</h2><div class="form-grid">
            <div class="field"><label asp-for="Form.CustomerId"></label><select name="CustomerId" id="admin-order-customer"><option value="">Müşteri seçin</option>@foreach (var customer in Model.Customers) { <option value="@customer.Id" selected="@(customer.Id == Model.Form.CustomerId)">@customer.Name (@customer.Email)</option> }</select></div>
            <div class="field"><label asp-for="Form.AddressId"></label><select name="AddressId" id="admin-order-address"><option value="">Teslimat adresi seçin</option>@foreach (var customer in Model.Customers) { foreach (var address in customer.Addresses) { <option value="@address.Id" data-customer="@customer.Id" selected="@(address.Id == Model.Form.AddressId)">@address.Title — @address.ContactName, @address.District / @address.City</option> } }</select></div>
            <div class="field"><label asp-for="Form.StartDate"></label><input type="date" name="StartDate" value="@Model.Form.StartDate.ToString("yyyy-MM-dd")" /></div>
            <div class="field"><label asp-for="Form.EndDate"></label><input type="date" name="EndDate" value="@Model.Form.EndDate.ToString("yyyy-MM-dd")" /></div>
        </div></div>
        <div class="form-section"><div class="section-heading"><div><h2>Talep edilen kitler</h2><p>Onay sonrasında bu modellerden belirtilen adet kadar siparişe özel fiziksel kit oluşturulur.</p></div><button class="secondary-action" type="button" id="add-admin-order-line">+ Kit ekle</button></div>
            <div class="recipe-lines" id="admin-order-lines">@for (var i = 0; i < Model.Form.Lines.Count; i++) { <div class="recipe-line admin-order-line"><span class="line-number">@(i + 1)</span><div class="field"><label>Kit modeli</label><select name="Lines[@i].ProductModelId"><option value="">Kit seçin</option>@foreach (var kit in Model.ProductModels) { <option value="@kit.Id" selected="@(kit.Id == Model.Form.Lines[i].ProductModelId)">@kit.Name (@kit.Sku)</option> }</select></div><div class="field quantity-field"><label>Adet</label><input type="number" min="1" max="100" name="Lines[@i].Quantity" value="@Model.Form.Lines[i].Quantity" /></div><button class="remove-line" type="button" title="Satırı kaldır">×</button></div> }</div>
        </div>
        <div class="form-actions"><a class="secondary-action" asp-action="Orders">Vazgeç</a><button class="primary-action" type="submit">Siparişi oluştur</button></div>
    </form>
</div>
<template id="admin-order-line-template"><div class="recipe-line admin-order-line"><span class="line-number"></span><div class="field"><label>Kit modeli</label><select data-name="ProductModelId"><option value="">Kit seçin</option>@foreach (var kit in Model.ProductModels) { <option value="@kit.Id">@kit.Name (@kit.Sku)</option> }</select></div><div class="field quantity-field"><label>Adet</label><input data-name="Quantity" type="number" min="1" max="100" value="1" /></div><button class="remove-line" type="button" title="Satırı kaldır">×</button></div></template>
<script>
(() => {
 const customer=document.querySelector('#admin-order-customer'), address=document.querySelector('#admin-order-address');
 const syncAddresses=()=>{const selected=customer.value;[...address.options].forEach((option,index)=>{if(index===0)return;option.hidden=option.dataset.customer!==selected;option.disabled=option.hidden;});if(address.selectedOptions[0]?.disabled)address.value=[...address.options].find(option=>!option.disabled&&option.value)?.value||'';};customer.addEventListener('change',syncAddresses);syncAddresses();
 const box=document.querySelector('#admin-order-lines'),tpl=document.querySelector('#admin-order-line-template');
 const renumber=()=>[...box.querySelectorAll('.admin-order-line')].forEach((row,i)=>{row.querySelector('.line-number').textContent=i+1;row.querySelectorAll('[name],[data-name]').forEach(el=>{const field=el.dataset.name||el.name.split('.').pop();el.name=`Lines[${i}].${field}`;});});
 document.querySelector('#add-admin-order-line').addEventListener('click',()=>{box.append(tpl.content.cloneNode(true));renumber();});box.addEventListener('click',e=>{if(!e.target.classList.contains('remove-line'))return;if(box.children.length>1)e.target.closest('.admin-order-line').remove();renumber();});renumber();
})();
</script>
