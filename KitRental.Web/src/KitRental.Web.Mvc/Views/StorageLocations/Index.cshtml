@model IReadOnlyCollection<StorageLocationViewModel>
@{ ViewData["Title"] = "Raf Düzeni"; }
<div class="catalog-heading"><div><span class="eyebrow">DEPO YÖNETİMİ</span><h1>Raf Düzeni</h1><p>Komponentlerin seçilebileceği depo ve raf konumlarını yönetin.</p></div><a class="primary-action" asp-action="Create">+ Yeni raf</a></div>
@if (TempData["Success"] is string success) { <div class="success-banner">@success</div> }
@if (TempData["Error"] is string error) { <div class="error-banner">@error</div> }
@if (Model.Count == 0)
{
    <div class="empty"><h2>Henüz raf kaydı yok</h2><p>İlk rafı oluşturarak komponentlere konum atamaya başlayın.</p><a class="primary-action" asp-action="Create">İlk rafı oluştur</a></div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead><tr><th>Raf kodu</th><th>Depo</th><th>Koridor</th><th>Raf</th><th>Göz</th><th>İşlemler</th></tr></thead>
            <tbody>
            @foreach (var location in Model)
            {
                <tr><td><strong>@location.Code</strong></td><td>@location.Warehouse</td><td>@location.Aisle</td><td>@location.Rack</td><td>@location.Shelf</td><td><div class="record-actions"><a asp-action="Edit" asp-route-id="@location.Id">Düzenle</a><form asp-action="Delete" asp-route-id="@location.Id" method="post" onsubmit="return confirm('Bu rafı silmek istediğinize emin misiniz? Stok veya hareket kaydı bulunan raflar silinemez.');"><button type="submit">Sil</button></form></div></td></tr>
            }
            </tbody>
        </table>
    </div>
}
