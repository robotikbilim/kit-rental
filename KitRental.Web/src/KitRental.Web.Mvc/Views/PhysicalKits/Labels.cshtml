@model PhysicalKitLabelsPageViewModel
@{ ViewData["Title"] = "Kit Etiketleri"; }
<div class="labels-page">
    <header class="labels-heading print-hidden">
        <div><span class="eyebrow">OLUŞTURMA TAMAMLANDI</span><h1>@Model.Labels.Count fiziksel kit hazır</h1><p>Her kit için benzersiz seri numarası ve QR kod oluşturuldu. Etiketleri A4 sayfaya yazdırabilirsiniz.</p></div>
        <div class="labels-actions"><a class="secondary-action" href="@(Model.BackUrl ?? Url.Action("Index"))">Fiziksel kitlere dön</a><button class="primary-action" type="button" onclick="window.print()">Etiketleri yazdır</button></div>
    </header>
    <div class="labels-print-meta print-only"><strong>KitRental Fiziksel Kit Etiketleri</strong><span>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm") · @Model.Labels.Count adet</span></div>
    <section class="label-grid">
        @foreach (var label in Model.Labels)
        {
            <article class="kit-label">
                <img src="@Url.Action("Qr", new { value = label.QrCode })" alt="@label.SerialNumber QR kodu" />
                <div class="kit-label-copy">
                    <span>KITRENTAL</span>
                    <strong>@label.KitName</strong>
                    <small>@label.KitSku</small>
                    <code>@label.SerialNumber</code>
                    <small class="qr-value">@label.QrCode</small>
                </div>
                <a class="label-detail-link print-hidden" asp-action="Details" asp-route-id="@label.Id" aria-label="@label.SerialNumber detayını aç">↗</a>
            </article>
        }
    </section>
    <div class="labels-footer print-hidden"><a class="secondary-action" asp-action="Create">+ Başka fiziksel kitler oluştur</a><button class="primary-action" type="button" onclick="window.print()">Etiketleri yazdır</button></div>
</div>
