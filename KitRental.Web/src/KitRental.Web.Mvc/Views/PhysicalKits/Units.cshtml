@model PhysicalKitUnitPageViewModel
@{
    ViewData["Title"] = $"{Model.KitName} Fiziksel Kitleri";
    string StatusName(int status) => status switch { 1 => "Kiralanabilir", 2 => "Rezerve", 3 => "Gönderim bekliyor", 4 => "Kargoya verildi", 5 => "Teslim edildi / kirada", 6 => "İade yolunda", 7 => "Kontrolde", 8 => "Serviste", 9 => "Karantina", 10 => "Kayıp", 11 => "Emekli", _ => "Bilinmiyor" };
    string FilterName() => Model.Filter switch { "available" => "Kiralanabilir kitler", "faulty" => "Arızalı kitler", _ => "Tüm fiziksel kitler" };
    var firstItem = Model.TotalCount == 0 ? 0 : (Model.Page - 1) * Model.PageSize + 1;
    var lastItem = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}
<a class="back-link" asp-action="Index">← Eğitim seti stoklarına dön</a>
@if (TempData["Success"] is string success) { <div class="success-banner">@success</div> }
@if (TempData["Error"] is string error) { <div class="error-banner">@error</div> }
<header class="unit-list-heading">
    <div class="unit-list-kit"><img src="@(Model.ImageUrl ?? "/images/catalog/kit.svg")" alt="@Model.KitName" /><div><span class="eyebrow">@Model.KitSku</span><h1>@Model.KitName</h1><p>@FilterName() · @Model.TotalCount kayıt</p></div></div>
    <div class="unit-list-actions">
        <nav class="stock-filter" aria-label="Fiziksel kit filtresi"><a class="@(Model.Filter == "all" ? "active" : null)" asp-action="Units" asp-route-id="@Model.ProductModelId" asp-route-filter="all">Tümü</a><a class="@(Model.Filter == "available" ? "active" : null)" asp-action="Units" asp-route-id="@Model.ProductModelId" asp-route-filter="available">Kiralanabilir</a><a class="@(Model.Filter == "faulty" ? "active" : null)" asp-action="Units" asp-route-id="@Model.ProductModelId" asp-route-filter="faulty">Arızalı</a></nav>
        @if (Model.TotalCount > 0) { <a class="primary-action" asp-action="Labels" asp-route-id="@Model.ProductModelId" asp-route-filter="@Model.Filter">QR etiketlerini yazdır</a> }
    </div>
</header>
@if (Model.Items.Count == 0)
{
    <div class="empty">Bu filtreye uygun fiziksel kit bulunmuyor.</div>
}
else
{
    <form asp-action="PrepareBulkRent" method="post" id="bulk-rent-selection-form">
    <input type="hidden" name="ProductModelId" value="@Model.ProductModelId" />
    <input type="hidden" name="Filter" value="@Model.Filter" />
    @if (Model.Filter == "available")
    {
        <div class="bulk-selection-bar">
            <span><strong id="selected-kit-count">0</strong> fiziksel kit seçildi</span>
            <button class="primary-action" id="bulk-rent-button" type="submit" disabled>Seçilenleri toplu kirala</button>
        </div>
    }
    <div class="table-scroll unit-table-wrap"><table><thead><tr>@if (Model.Filter == "available") { <th class="unit-select-cell"><input id="select-all-kits" type="checkbox" aria-label="Bu sayfadaki tüm kitleri seç" /></th> }<th>Seri numarası</th><th>QR kod</th><th>Durum</th><th>Mevcut kiracı</th><th></th></tr></thead><tbody>
    @foreach (var kit in Model.Items)
    {
        <tr>@if (Model.Filter == "available") { <td class="unit-select-cell"><input class="kit-selection" type="checkbox" name="ProductUnitIds" value="@kit.Id" aria-label="@kit.SerialNumber seri numaralı kiti seç" /></td> }<td><code class="unit-serial">@kit.SerialNumber</code></td><td><span class="unit-qr">@kit.QrCode</span></td><td><span class="fleet-status status-@kit.Status">@StatusName(kit.Status)</span></td><td>@if(kit.CurrentRental is null){<span>—</span>}else{<strong>@kit.CurrentRental.CustomerName</strong><small class="block-muted">@kit.CurrentRental.City · @kit.CurrentRental.StartDate.ToString("dd.MM.yyyy")–@kit.CurrentRental.EndDate.ToString("dd.MM.yyyy")</small>}</td><td><div class="record-actions"><a asp-action="Details" asp-route-id="@kit.Id">Geçmiş</a><a asp-action="Edit" asp-route-id="@kit.Id">Güncelle</a><button type="submit" asp-action="Delete" asp-route-id="@kit.Id" asp-route-productModelId="@Model.ProductModelId" asp-route-filter="@Model.Filter" asp-route-page="@Model.Page" onclick="return confirm('Bu fiziksel kiti silmek istediğinize emin misiniz?');">Sil</button></div></td></tr>
    }
    </tbody></table></div>
    <footer class="pagination-shell">
        <span>@firstItem–@lastItem / @Model.TotalCount kayıt</span>
        <nav class="pagination" aria-label="Sayfalar">
            @if (Model.Page > 1) { <a asp-action="Units" asp-route-id="@Model.ProductModelId" asp-route-filter="@Model.Filter" asp-route-page="@(Model.Page - 1)">←</a> }
            @for (var pageNumber = Math.Max(1, Model.Page - 2); pageNumber <= Math.Min(Model.TotalPages, Model.Page + 2); pageNumber++)
            { <a class="@(pageNumber == Model.Page ? "active" : null)" asp-action="Units" asp-route-id="@Model.ProductModelId" asp-route-filter="@Model.Filter" asp-route-page="@pageNumber">@pageNumber</a> }
            @if (Model.Page < Model.TotalPages) { <a asp-action="Units" asp-route-id="@Model.ProductModelId" asp-route-filter="@Model.Filter" asp-route-page="@(Model.Page + 1)">→</a> }
        </nav>
    </footer>
    </form>
    @if (Model.Filter == "available")
    {
        <script>
        (() => {
            const all = document.querySelector('#select-all-kits');
            const boxes = [...document.querySelectorAll('.kit-selection')];
            const count = document.querySelector('#selected-kit-count');
            const button = document.querySelector('#bulk-rent-button');
            const update = () => {
                const selected = boxes.filter(box => box.checked).length;
                count.textContent = selected;
                button.disabled = selected === 0;
                all.checked = selected === boxes.length && boxes.length > 0;
                all.indeterminate = selected > 0 && selected < boxes.length;
            };
            all.addEventListener('change', () => { boxes.forEach(box => box.checked = all.checked); update(); });
            boxes.forEach(box => box.addEventListener('change', update));
            update();
        })();
        </script>
    }
}
