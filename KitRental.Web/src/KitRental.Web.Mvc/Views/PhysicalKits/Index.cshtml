@model IReadOnlyCollection<PhysicalKitModelSummaryViewModel>
@{ ViewData["Title"] = "Fiziksel Kit Stoğu"; }
<div class="catalog-heading kit-stock-heading">
    <div><span class="eyebrow">EĞİTİM SETİ BAZLI STOK</span><h1>Fiziksel kit stoğu</h1><p>Her eğitim setinden üretilen, kiralanabilir ve arızalı fiziksel kit sayılarını izleyin.</p></div>
    <div class="recipe-actions"><a class="secondary-action" asp-action="Lookup">⌕ Kit geçmişi sorgula</a><a class="primary-action" asp-action="Create">+ Fiziksel kit oluştur</a></div>
</div>
@if (TempData["Success"] is string success) { <div class="success-banner">@success</div> }
@if (Model.Count == 0)
{
    <div class="empty">Henüz tanımlanmış eğitim seti bulunmuyor.</div>
}
else
{
    <section class="kit-model-grid">
    @foreach (var kit in Model)
    {
        <article class="kit-model-stock-card">
            <div class="kit-model-image"><img src="@(kit.ImageUrl ?? "/images/catalog/kit.svg")" alt="@kit.KitName" /></div>
            <div class="kit-model-identity"><span>@kit.KitSku</span><h2>@kit.KitName</h2></div>
            <div class="kit-stock-counts">
                <a asp-action="Units" asp-route-id="@kit.ProductModelId" asp-route-filter="all"><span>Toplam üretilen</span><strong>@kit.Total</strong><small>Seri numaralarını gör →</small></a>
                <a class="available" asp-action="Units" asp-route-id="@kit.ProductModelId" asp-route-filter="available"><span>Kiralanabilir</span><strong>@kit.Available</strong><small>Hazır kitleri gör →</small></a>
                <a class="faulty" asp-action="Units" asp-route-id="@kit.ProductModelId" asp-route-filter="faulty"><span>Arızalı</span><strong>@kit.Faulty</strong><small>Arızalı kitleri gör →</small></a>
            </div>
            <div class="kit-model-actions">
                @if (kit.Total > 0) { <a asp-action="Labels" asp-route-id="@kit.ProductModelId" asp-route-filter="all">QR etiketlerini yazdır</a> }
                else { <span>Henüz fiziksel kit oluşturulmamış</span> }
            </div>
        </article>
    }
    </section>
}
