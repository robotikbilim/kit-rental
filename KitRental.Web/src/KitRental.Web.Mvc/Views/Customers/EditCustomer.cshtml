@model CustomerInputViewModel
@{ ViewData["Title"] = "Müşteri Düzenle"; }
<div class="form-shell customer-form-shell"><div class="form-heading"><a asp-action="Index">← Müşterilere dön</a><span class="eyebrow">MÜŞTERİ KARTI</span><h1>Müşteri bilgilerini düzenle</h1><p>Kurumsal adı, iletişim e-postasını ve müşteri durumunu güncelleyin.</p></div><form class="catalog-form" asp-action="Edit" method="post"><input asp-for="Id" type="hidden" /><div asp-validation-summary="All" class="error"></div><div class="form-section"><div class="form-grid"><div class="field wide"><label asp-for="Name"></label><input asp-for="Name" /></div><div class="field wide"><label asp-for="Email"></label><input asp-for="Email" /></div><label class="customer-active-check"><input asp-for="IsActive" /> <span><strong>Aktif müşteri</strong><small>Aktif müşteriler yeni siparişlerde seçilebilir.</small></span></label></div></div><div class="form-actions"><a class="secondary-action" asp-action="Index">Vazgeç</a><button class="primary-action" type="submit">Değişiklikleri kaydet</button></div></form></div>
