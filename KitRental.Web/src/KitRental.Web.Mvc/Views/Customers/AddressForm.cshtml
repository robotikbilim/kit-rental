@model CustomerAddressInputViewModel
@{ var editing = Model.Id != Guid.Empty; ViewData["Title"] = editing ? "Sipariş Adresi Düzenle" : "Yeni Sipariş Adresi"; }
<div class="form-shell form-shell-wide customer-form-shell"><div class="form-heading"><a asp-action="Index">← Müşterilere dön</a><span class="eyebrow">@Model.CustomerName</span><h1>@(editing ? "Sipariş adresini düzenle" : "Yeni sipariş adresi ekle")</h1><p>Bu adres, yeni sipariş oluştururken teslimat noktası olarak seçilebilecek.</p></div><form class="catalog-form" asp-action="@(editing ? "EditAddress" : "CreateAddress")" method="post"><input asp-for="CustomerId" type="hidden" /><input asp-for="Id" type="hidden" /><input asp-for="CustomerName" type="hidden" /><div asp-validation-summary="All" class="error"></div><div class="form-section"><partial name="_AddressFields" model="Model" /></div><div class="form-actions"><a class="secondary-action" asp-action="Index">Vazgeç</a><button class="primary-action" type="submit">@(editing ? "Adresi güncelle" : "Adresi ekle")</button></div></form></div>
