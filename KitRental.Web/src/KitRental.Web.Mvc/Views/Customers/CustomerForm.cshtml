@model CreateCustomerViewModel
@{ ViewData["Title"] = "Yeni Müşteri"; }
<div class="form-shell form-shell-wide customer-form-shell"><div class="form-heading"><a asp-action="Index">← Müşterilere dön</a><span class="eyebrow">YENİ MÜŞTERİ</span><h1>Müşteri kartı oluştur</h1><p>Müşterinin temel bilgilerini ve siparişte kullanılacak ilk teslimat adresini kaydedin.</p></div>
<form class="catalog-form" asp-action="Create" method="post"><div asp-validation-summary="All" class="error"></div><div class="form-section"><h2>Müşteri bilgileri</h2><div class="form-grid"><div class="field"><label asp-for="Customer.Name"></label><input asp-for="Customer.Name" placeholder="Örn. Robotik Bilim Eğitim A.Ş." /></div><div class="field"><label asp-for="Customer.Email"></label><input asp-for="Customer.Email" placeholder="siparis@kurum.com" /></div></div></div><div class="form-section"><h2>İlk sipariş adresi</h2><p class="section-note">Daha sonra aynı müşteriye farklı teslimat adresleri ekleyebilirsiniz.</p><partial name="_AddressFields" for="Address" /></div><div class="form-actions"><a class="secondary-action" asp-action="Index">Vazgeç</a><button class="primary-action" type="submit">Müşteriyi kaydet</button></div></form></div>
