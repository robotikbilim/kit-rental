@model CustomerAddressInputViewModel
<div class="form-grid address-form-grid"><div class="field"><label asp-for="Title"></label><input asp-for="Title" placeholder="Örn. Merkez, Şube, Depo" /></div><div class="field"><label asp-for="ContactName"></label><input asp-for="ContactName" placeholder="Teslim alacak kişi" /></div><div class="field"><label asp-for="Phone"></label><input asp-for="Phone" placeholder="0 (5xx) xxx xx xx" /></div><div class="field"><label asp-for="PostalCode"></label><input asp-for="PostalCode" placeholder="34000" /></div><div class="field wide"><label asp-for="Line1"></label><textarea asp-for="Line1" rows="3" placeholder="Mahalle, cadde, sokak, bina ve kapı numarası"></textarea></div><div class="field"><label asp-for="District"></label><input asp-for="District" /></div><div class="field"><label asp-for="City"></label><input asp-for="City" /></div></div>
