<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - KitRental</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="topbar">
        @{ var isCustomer = User.IsInRole("CustomerAccountManager") || User.IsInRole("CustomerUser"); }
        <a class="brand" asp-controller="@(isCustomer ? "CustomerPortal" : "Operations")" asp-action="@(isCustomer ? "Index" : "Dashboard")">@(isCustomer ? "TACEV Kit Portalı" : "RB Atölye")</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="main-menu" aria-label="Menüyü aç">
                <span></span><span></span><span></span>
            </button>
            <div class="topbar-menu" id="main-menu">
                <nav aria-label="Ana menü">
                    @if (isCustomer)
                    {
                        <a asp-controller="CustomerPortal" asp-action="Index">Kitlerim</a>
                        <a asp-controller="CustomerPortal" asp-action="FindKit">QR ile Kit Bul</a>
                        <a asp-controller="CustomerPortal" asp-action="NewRequest">Yeni Kiralama Talebi</a>
                        <a asp-controller="CustomerPortal" asp-action="Index" asp-fragment="faults">Arızalarım</a>
                    }
                    else
                    {
                        <a asp-controller="Operations" asp-action="Dashboard">Genel Bakış</a>
                        <a asp-controller="Operations" asp-action="Inventory">Envanter</a>
                        <a asp-controller="PhysicalKits" asp-action="Index">Fiziksel Kitler</a>
                        <a asp-controller="PhysicalKits" asp-action="Lookup">Kit Geçmişi</a>
                        <a asp-controller="Catalog" asp-action="Kits">Eğitim Kitleri</a>
                        <a asp-controller="Manufacturing" asp-action="Index">Üretilebilirlik</a>
                        <a asp-controller="Catalog" asp-action="Components">Komponentler</a>
                        <a asp-controller="StorageLocations" asp-action="Index">Raf Düzeni</a>
                        <a asp-controller="SupplyNeeds" asp-action="Index">İhtiyaç Listeleri</a>
                        <a asp-controller="Workshop" asp-action="Index">Komponent Bul</a>
                        @if (User.IsInRole("SystemAdmin") || User.IsInRole("OperationsManager"))
                        {
                            <a asp-controller="Customers" asp-action="Index">Müşteriler</a>
                        }
                        <a asp-controller="Operations" asp-action="Orders">Siparişler</a>
                        <a asp-controller="Operations" asp-action="Faults">Arızalar</a>
                    }
                </nav>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <span>@User.Identity.Name</span><button class="link-button" type="submit">Çıkış</button>
                </form>
            </div>
        }
    </header>
    <main class="container">@RenderBody()</main>
    <script src="~/js/site.js"></script>
</body>
</html>
