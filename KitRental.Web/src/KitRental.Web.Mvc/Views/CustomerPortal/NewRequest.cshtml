@model PortalRentalRequestPageViewModel
@{ ViewData["Title"] = "Yeni Kiralama Talebi"; }
<div class="form-shell form-shell-wide">
    <div class="form-heading"><a asp-action="Index">← Kitlerime dön</a><span class="eyebrow">YENİ KİRALAMA</span><h1>Kiralama talebi oluştur</h1><p>İhtiyacınız olan eğitim kitlerini ve tarih aralığını seçin. Talebiniz operasyon yöneticisinin onayına gönderilir.</p></div>
    <form class="catalog-form" asp-action="NewRequest" method="post">
        <div asp-validation-summary="All" class="error"></div>
        <div class="form-section"><h2>Teslimat ve dönem</h2><div class="form-grid">
            <div class="field wide"><label asp-for="Form.AddressId"></label><select name="AddressId" id="AddressId">@foreach (var address in Model.Addresses) { <option value="@address.Id" selected="@(address.Id == Model.Form.AddressId ? "selected" : null)">@address.Title — @address.Line1, @address.District / @address.City</option> }</select></div>
            <div class="field"><label asp-for="Form.StartDate"></label><input type="date" name="StartDate" value="@Model.Form.StartDate.ToString("yyyy-MM-dd")" /></div>
            <div class="field"><label asp-for="Form.EndDate"></label><input type="date" name="EndDate" value="@Model.Form.EndDate.ToString("yyyy-MM-dd")" /></div>
        </div></div>
        <div class="form-section"><div class="section-heading"><div><h2>Talep edilen kitler</h2><p>Bir talepte birden fazla kit modeli ve adet belirleyebilirsiniz.</p></div><button class="secondary-action" type="button" id="add-rental-line">+ Kit ekle</button></div>
            <div class="recipe-lines" id="rental-lines">
            @for (var i = 0; i < Model.Form.Lines.Count; i++) { <div class="recipe-line rental-line"><span class="line-number">@(i + 1)</span><div class="field"><label>Kit modeli</label><select name="Lines[@i].ProductModelId"><option value="">Kit seçin</option>@foreach (var kit in Model.ProductModels) { <option value="@kit.Id" selected="@(kit.Id == Model.Form.Lines[i].ProductModelId ? "selected" : null)">@kit.Name (@kit.Sku)</option> }</select></div><div class="field quantity-field"><label>Adet</label><input type="number" min="1" max="100" name="Lines[@i].Quantity" value="@Model.Form.Lines[i].Quantity" /></div><button class="remove-line" type="button" title="Satırı kaldır">×</button></div> }
            </div>
        </div>
        <div class="form-actions"><a class="secondary-action" asp-action="Index">Vazgeç</a><button class="primary-action" type="submit">Talebi onaya gönder</button></div>
    </form>
</div>
<template id="rental-line-template"><div class="recipe-line rental-line"><span class="line-number"></span><div class="field"><label>Kit modeli</label><select data-name="ProductModelId"><option value="">Kit seçin</option>@foreach (var kit in Model.ProductModels) { <option value="@kit.Id">@kit.Name (@kit.Sku)</option> }</select></div><div class="field quantity-field"><label>Adet</label><input data-name="Quantity" type="number" min="1" max="100" value="1" /></div><button class="remove-line" type="button" title="Satırı kaldır">×</button></div></template>
<script>
(() => { const box=document.querySelector('#rental-lines'), tpl=document.querySelector('#rental-line-template');
 const renumber=()=>[...box.querySelectorAll('.rental-line')].forEach((row,i)=>{row.querySelector('.line-number').textContent=i+1;row.querySelectorAll('[name],[data-name]').forEach(el=>{const field=el.dataset.name||el.name.split('.').pop();el.name=`Lines[${i}].${field}`;});});
 document.querySelector('#add-rental-line').addEventListener('click',()=>{box.append(tpl.content.cloneNode(true));renumber();});
 box.addEventListener('click',e=>{if(!e.target.classList.contains('remove-line'))return;if(box.children.length>1)e.target.closest('.rental-line').remove();else{box.querySelector('select').value='';box.querySelector('input').value=1;}renumber();}); renumber(); })();
</script>
