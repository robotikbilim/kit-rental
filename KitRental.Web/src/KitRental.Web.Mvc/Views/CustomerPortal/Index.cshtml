@model CustomerPortalViewModel
@{
    ViewData["Title"] = "Kitlerim";
    var visibleKits = Model.Kits.Where(item => item.AssignmentStatus is 1 or 2).ToArray();
}
@functions {
    string UnitStatus(int value) => value switch { 1 => "Hazır", 2 => "Rezerve", 3 => "Hazırlanıyor", 4 => "Teslimat yolunda", 5 => "Kullanımınızda", 6 => "Geri gönderiliyor", 7 => "Kontrolde", 8 => "Serviste", _ => "İşlemde" };
    string OrderStatus(int value) => value switch { 2 => "Onay bekliyor", 3 => "Onaylandı", 4 => "Hazırlanıyor", 5 => "Kargoya hazır", 6 => "Teslimat yolunda", 7 => "Teslim edildi", 8 => "Kiralama aktif", 9 => "İade bekleniyor", 10 => "İade yolunda", 11 => "Kontrolde", 13 => "Tamamlandı", 14 => "Reddedildi", 15 => "İptal edildi", _ => "Taslak" };
    string FaultStatus(int value) => value switch { 1 => "Kayıt açıldı", 2 => "İnceleniyor", 3 => "Bilgi bekleniyor", 4 => "Kitin gönderilmesi bekleniyor", 5 => "Serviste", 6 => "Geri gönderiliyor", 7 => "Çözüldü", 8 => "Kapatıldı", _ => "İşlemde" };
}
<div class="portal-heading">
    <div><span class="eyebrow">TACEV KİRALAMA PORTALI</span><h1>Merhaba, @Model.CustomerName</h1><p>Kitlerinizi, kiralama taleplerinizi ve servis süreçlerinizi tek ekrandan takip edin.</p></div>
    <div class="recipe-actions"><a class="secondary-action" asp-action="FindKit">▣ QR ile kit bul</a><a class="primary-action" asp-action="NewRequest">+ Yeni kiralama talebi</a></div>
</div>
@if (TempData["Success"] is string message) { <div class="success-banner">@message</div> }
<section class="metrics portal-metrics">
    <article><span>Kullanımınızdaki kit</span><strong>@Model.ActiveKitCount</strong></article>
    <article><span>Onay bekleyen talep</span><strong>@Model.PendingRequestCount</strong></article>
    <article><span>Açık arıza kaydı</span><strong>@Model.OpenFaultCount</strong></article>
</section>

<section class="portal-section">
    <div class="section-heading"><div><span class="eyebrow">KİRALANAN ÜRÜNLER</span><h2>Kitlerim</h2></div><b class="portal-kit-count">@visibleKits.Length kit</b></div>
    @if (visibleKits.Length > 0)
    {
        <div class="table-scroll portal-kit-table-wrap" id="portal-kit-table" data-page-size="5">
            <table class="portal-kit-table">
                <thead><tr><th>Kit</th><th>Seri numarası</th><th>Kiralama dönemi</th><th>Durum</th><th>Arıza</th><th><span class="visually-hidden">İşlemler</span></th></tr></thead>
                <tbody>
                @foreach (var kit in visibleKits)
                {
                    <tr>
                        <td><div class="table-kit"><img src="@(kit.ImageUrl ?? "/images/kit-placeholder.svg")" alt="" /><div><strong>@kit.KitName</strong><small>@kit.KitSku</small></div></div></td>
                        <td><code class="unit-serial">@kit.SerialNumber</code></td>
                        <td><span class="portal-kit-period">@kit.StartDate.ToString("dd.MM.yyyy")<small>@kit.EndDate.ToString("dd.MM.yyyy") tarihine kadar</small></span></td>
                        <td><span class="fleet-status status-@kit.UnitStatus">@UnitStatus(kit.UnitStatus)</span></td>
                        <td>@if (kit.OpenFaultCount > 0) { <span class="portal-alert">@kit.OpenFaultCount açık arıza</span> } else { <span class="portal-no-fault">Arıza yok</span> }</td>
                        <td>@if (kit.AssignmentStatus == 2) { <div class="portal-table-actions"><a class="row-link" asp-action="Kit" asp-route-id="@kit.ProductUnitId">Detay</a><a class="row-link fault-link" asp-action="NewFault" asp-route-assignmentId="@kit.AssignmentId">Arıza bildir</a></div> }</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <footer class="pagination-shell portal-kit-pagination" id="portal-kit-pagination">
            <span id="portal-kit-page-summary"></span>
            <nav class="pagination" id="portal-kit-page-buttons" aria-label="Kitlerim sayfaları"></nav>
        </footer>
    }
    else { <div class="empty">Aktif veya hazırlanmakta olan kiralık kitiniz bulunmuyor.</div> }
</section>

<section class="portal-section">
    <div class="section-heading"><div><span class="eyebrow">TALEP TAKİBİ</span><h2>Kiralama taleplerim</h2></div><a class="row-link" asp-action="NewRequest">Yeni talep oluştur →</a></div>
    <div class="table-scroll"><table><thead><tr><th>Talep</th><th>Kitler</th><th>Dönem</th><th>Oluşturulma</th><th>Durum</th></tr></thead><tbody>
    @foreach (var order in Model.Orders) { <tr><td><strong>@order.OrderNumber</strong></td><td>@string.Join(", ", order.Lines.Select(line => $"{line.ProductName} × {line.Quantity}"))</td><td>@order.StartDate.ToString("dd.MM.yyyy") – @order.EndDate.ToString("dd.MM.yyyy")</td><td>@order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td><td><span class="badge order-status-@order.Status">@OrderStatus(order.Status)</span></td></tr> }
    </tbody></table></div>
    @if (Model.Orders.Count == 0) { <div class="empty">Henüz kiralama talebiniz yok.</div> }
</section>
<script src="~/js/customer-portal-kits.js"></script>

<section class="portal-section" id="faults">
    <div class="section-heading"><div><span class="eyebrow">SERVİS TAKİBİ</span><h2>Arıza kayıtlarım</h2></div><a class="secondary-action" asp-action="NewFault">Arıza bildir</a></div>
    <div class="portal-fault-grid">
    @foreach (var fault in Model.Faults)
    {
        <a asp-action="Fault" asp-route-id="@fault.Id" class="portal-fault-card">
            <div><small>@fault.Number · @fault.SerialNumber</small><h3>@fault.KitName</h3><p>@fault.Description</p></div>
            <div><span class="fault-stage status-@fault.Status">@FaultStatus(fault.Status)</span><small>@fault.OpenedAt.ToLocalTime().ToString("dd.MM.yyyy")</small></div>
        </a>
    }
    </div>
    @if (Model.Faults.Count == 0) { <div class="empty">Henüz arıza kaydınız yok.</div> }
</section>
