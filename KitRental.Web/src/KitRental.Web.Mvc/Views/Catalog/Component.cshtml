@model ComponentLocatorViewModel
@{ ViewData["Title"] = Model.Name; }
@if (TempData["Success"] is string message) { <div class="success-banner">@message</div> }
<a class="back-link" asp-action="Components">← Komponentler</a>
<div class="detail-hero"><div class="detail-image"><img src="@(Model.ImageUrl ?? Url.Content("~/images/component-placeholder.svg"))" alt="@Model.Name" /></div><div><span class="eyebrow">@Model.Sku</span><h1>@Model.Name</h1><p>Minimum stok: @Model.MinimumStock.ToString("0.###") @Model.UnitOfMeasure</p><span class="stock-state @(Model.IsLowStock ? "low" : "ok")">@(Model.IsLowStock ? "Stok kritik seviyede" : "Stok seviyesi yeterli")</span></div><div class="stock-total"><span>Toplam stok</span><strong>@Model.TotalStock.ToString("0.###")</strong><small>@Model.UnitOfMeasure</small></div></div>
<section class="detail-section"><div class="section-heading"><div><span class="eyebrow">LOKASYONLAR</span><h2>Raf bazlı stok</h2></div></div><div class="location-grid">@foreach(var location in Model.Locations){<article class="location-card"><div class="location-code">@location.LocationCode</div><div class="location-route">@location.Warehouse • Koridor @location.Aisle • Raf @location.Rack • Göz @location.Shelf</div><div class="location-quantity"><strong>@location.Quantity.ToString("0.###")</strong><span>@Model.UnitOfMeasure</span></div></article>}</div>@if(Model.Locations.Count==0){<div class="empty">Raf bilgisi: Bilinmiyor.</div>}</section>
