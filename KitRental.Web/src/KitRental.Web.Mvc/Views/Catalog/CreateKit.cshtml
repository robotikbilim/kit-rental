@model CreateKitPageViewModel
@{ ViewData["Title"] = "Yeni Eğitim Kiti"; }
<div class="form-shell form-shell-wide">
    <div class="form-heading"><a asp-action="Kits">← Eğitim Kitleri</a><span class="eyebrow">KİT + REÇETE</span><h1>Yeni eğitim kiti</h1><p>Kit kartını ve üretimde kullanılacak komponentleri birlikte tanımlayın.</p></div>
    <form method="post" class="catalog-form" id="kit-form">
        <div asp-validation-summary="All" class="error"></div>
        <section class="form-section"><h2>Kit bilgileri</h2>
            <div class="form-grid">
                <div class="field wide"><label for="Name">Eğitim kiti adı</label><input id="Name" name="Name" value="@Model.Form.Name" required placeholder="Örn. Çizgi İzleyen Robot Kiti" /></div>
                <div class="field"><label for="Sku">SKU / ürün kodu</label><input id="Sku" name="Sku" value="@Model.Form.Sku" required placeholder="KIT-LINE-01" /></div>
                <div class="field"><label for="BomVersion">Reçete sürümü</label><input id="BomVersion" name="BomVersion" value="@Model.Form.BomVersion" type="number" min="1" required /></div>
                <div class="field wide"><label for="Description">Açıklama</label><textarea id="Description" name="Description" rows="3" placeholder="Kitin eğitim amacı ve kapsamı...">@Model.Form.Description</textarea></div>
                <div class="field wide"><label for="ImageUrl">Görsel adresi</label><input id="ImageUrl" name="ImageUrl" value="@Model.Form.ImageUrl" placeholder="https://.../kit.jpg" /></div>
            </div>
        </section>
        <section class="form-section recipe-builder">
            <div class="section-heading"><div><h2>Üretim reçetesi</h2><p>Bir kit üretmek için gereken komponent ve adetleri ekleyin.</p></div><button type="button" class="secondary-action" id="add-line">+ Komponent ekle</button></div>
            <div class="recipe-lines" id="recipe-lines">
            @for (var index = 0; index < Model.Form.Lines.Count; index++)
            {
                <div class="recipe-line">
                    <span class="line-number">@(index + 1)</span>
                    <div class="field"><label>Komponent</label><select name="Lines[@index].ComponentId" required><option value="">Komponent seçin</option>@foreach (var component in Model.Components) { <option value="@component.Id" selected="@(component.Id == Model.Form.Lines[index].ComponentId)">@component.Name — @component.Sku (stok: @component.TotalStock.ToString("0.###"))</option> }</select></div>
                    <div class="field quantity-field"><label>Adet / miktar</label><input name="Lines[@index].Quantity" value="@Model.Form.Lines[index].Quantity" type="number" min="0.001" step="0.001" required /></div>
                    <button type="button" class="remove-line" aria-label="Satırı kaldır">×</button>
                </div>
            }
            </div>
        </section>
        <div class="form-actions"><a asp-action="Kits" class="secondary-action">Vazgeç</a><button type="submit" class="primary-action">Kiti ve reçeteyi kaydet</button></div>
    </form>
</div>
<template id="recipe-template"><div class="recipe-line"><span class="line-number"></span><div class="field"><label>Komponent</label><select required><option value="">Komponent seçin</option>@foreach (var component in Model.Components) { <option value="@component.Id">@component.Name — @component.Sku (stok: @component.TotalStock.ToString("0.###"))</option> }</select></div><div class="field quantity-field"><label>Adet / miktar</label><input type="number" min="0.001" step="0.001" value="1" required /></div><button type="button" class="remove-line" aria-label="Satırı kaldır">×</button></div></template>
<script>
(() => {
 const lines=document.getElementById('recipe-lines'), template=document.getElementById('recipe-template');
 const renumber=()=>[...lines.querySelectorAll('.recipe-line')].forEach((row,i)=>{row.querySelector('.line-number').textContent=i+1;row.querySelector('select').name=`Lines[${i}].ComponentId`;row.querySelector('input').name=`Lines[${i}].Quantity`;});
 document.getElementById('add-line').addEventListener('click',()=>{lines.appendChild(template.content.cloneNode(true));renumber();});
 lines.addEventListener('click',e=>{if(!e.target.classList.contains('remove-line'))return;if(lines.children.length===1){lines.querySelector('select').value='';lines.querySelector('input').value='1';return;}e.target.closest('.recipe-line').remove();renumber();});
 renumber();
})();
</script>
