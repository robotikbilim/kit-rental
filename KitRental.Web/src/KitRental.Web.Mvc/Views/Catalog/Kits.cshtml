@model IReadOnlyCollection<ProductModelCatalogViewModel>
@{ ViewData["Title"] = "Eğitim Kitleri"; }
<div class="catalog-heading"><div><span class="eyebrow">ÜRÜN VE ÜRETİM</span><h1>Eğitim Kitleri</h1><p>Kitleri, görsellerini ve üretim reçetelerini yönetin.</p></div><a class="primary-action" asp-action="CreateKit">+ Yeni eğitim kiti</a></div>
@if (TempData["Success"] is string message) { <div class="success-banner">@message</div> }
@if (TempData["Error"] is string error) { <div class="error-banner">@error</div> }
<div class="catalog-grid">
@foreach (var kit in Model)
{
    <article class="catalog-card">
        <a class="catalog-card-main" asp-action="Kit" asp-route-id="@kit.Id"><div class="catalog-image"><img src="@(kit.ImageUrl ?? Url.Content("~/images/catalog/kit.svg"))" alt="@kit.Name" /></div><div class="catalog-card-body"><span>@kit.Sku</span><h2>@kit.Name</h2><p>@(kit.Description ?? "Eğitim seti ayrıntılarını görüntüleyin.")</p><strong>Detayı aç →</strong></div></a>
        <div class="record-actions"><a asp-action="EditKit" asp-route-id="@kit.Id">Güncelle</a><form asp-action="DeleteKit" asp-route-id="@kit.Id" method="post" onsubmit="return confirm('Bu eğitim setini silmek istediğinize emin misiniz?');"><button type="submit">Sil</button></form></div>
    </article>
}
</div>
@if (Model.Count == 0) { <div class="empty">Henüz eğitim kiti yok.</div> }
